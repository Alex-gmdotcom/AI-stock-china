"""
AKShare-based data provider for China A-share and Hong Kong markets.

This module mirrors the interface of src/tools/api.py but fetches data
from AKShare (https://akshare.akfamily.xyz/) instead of financialdatasets.ai.

AKShare is an open-source Python library that provides free access to
Chinese financial market data from multiple sources (东方财富/新浪/同花顺/etc.).

Install: pip install akshare

Usage:
    from src.tools.api_china import (
        get_prices, get_financial_metrics, get_company_news,
        get_northbound_flow, get_margin_trading, get_main_capital_flow,
        get_sector_performance, get_stock_sector_info,
    )
"""

from __future__ import annotations

import datetime
import logging
import pandas as pd

from src.data.cache import get_cache
from src.data.models import Price, FinancialMetrics, CompanyNews
from src.data.models_china import (
    NorthboundFlow,
    MarginTrading,
    MainCapitalFlow,
    SectorPerformance,
    SectorInfo,
    SouthboundFlow,
    PublicOpinionItem,
)
from src.markets.ticker import TickerInfo, parse_ticker

logger = logging.getLogger(__name__)
_cache = get_cache()


def _ensure_akshare():
    """Lazy import akshare to avoid hard dependency at module level."""
    try:
        import akshare as ak
        return ak
    except ImportError:
        raise ImportError(
            "AKShare is required for China/HK market data. "
            "Install it with: pip install akshare"
        )


# ═══════════════════════════════════════════════
# Price data
# ═══════════════════════════════════════════════

def get_prices(
    ticker: str,
    start_date: str,
    end_date: str,
) -> list[Price]:
    """
    Fetch daily OHLCV price data for a CN/HK stock.

    Args:
        ticker: Stock code (e.g. "600519", "600519.SH", "00700.HK")
        start_date: Start date in YYYY-MM-DD format
        end_date: End date in YYYY-MM-DD format

    Returns:
        List of Price objects compatible with the base system.
    """
    cache_key = f"cn_{ticker}_{start_date}_{end_date}"
    if cached := _cache.get_prices(cache_key):
        return [Price(**p) for p in cached]

    ak = _ensure_akshare()
    info = parse_ticker(ticker)

    try:
        if info.market.is_china:
            df = _fetch_cn_prices(ak, info, start_date, end_date)
        elif info.market.is_hk:
            df = _fetch_hk_prices(ak, info, start_date, end_date)
        else:
            logger.warning("US ticker %s passed to China API; use api.py instead", ticker)
            return []
    except Exception as e:
        logger.warning("Failed to fetch prices for %s: %s", ticker, e)
        return []

    if df is None or df.empty:
        return []

    prices = _dataframe_to_prices(df)

    _cache.set_prices(cache_key, [p.model_dump() for p in prices])
    return prices


def _fetch_cn_prices(ak, info: TickerInfo, start_date: str, end_date: str) -> pd.DataFrame:
    """Fetch A-share daily prices via AKShare."""
    # ak.stock_zh_a_hist returns: 日期,开盘,收盘,最高,最低,成交量,成交额,...
    start_fmt = start_date.replace("-", "")
    end_fmt = end_date.replace("-", "")

    df = ak.stock_zh_a_hist(
        symbol=info.code,
        period="daily",
        start_date=start_fmt,
        end_date=end_fmt,
        adjust="qfq",  # 前复权 (forward-adjusted)
    )
    return df


def _fetch_hk_prices(ak, info: TickerInfo, start_date: str, end_date: str) -> pd.DataFrame:
    """Fetch HK stock daily prices via AKShare."""
    start_fmt = start_date.replace("-", "")
    end_fmt = end_date.replace("-", "")

    df = ak.stock_hk_hist(
        symbol=info.code,
        period="daily",
        start_date=start_fmt,
        end_date=end_fmt,
        adjust="qfq",
    )
    return df


def _dataframe_to_prices(df: pd.DataFrame) -> list[Price]:
    """Convert AKShare DataFrame to list of Price objects."""
    # AKShare columns vary by function; normalize common patterns
    col_map = {
        "日期": "time", "开盘": "open", "收盘": "close",
        "最高": "high", "最低": "low", "成交量": "volume",
        # English columns (some AKShare functions)
        "date": "time", "Date": "time",
    }
    df = df.rename(columns=col_map)

    required = ["time", "open", "close", "high", "low", "volume"]
    for col in required:
        if col not in df.columns:
            # Try to find a fuzzy match
            for orig, mapped in col_map.items():
                if mapped == col and orig in df.columns:
                    df = df.rename(columns={orig: col})
                    break

    prices = []
    for _, row in df.iterrows():
        try:
            time_val = str(row.get("time", ""))
            if hasattr(row.get("time"), "strftime"):
                time_val = row["time"].strftime("%Y-%m-%d")

            prices.append(Price(
                open=float(row.get("open", 0)),
                close=float(row.get("close", 0)),
                high=float(row.get("high", 0)),
                low=float(row.get("low", 0)),
                volume=int(float(row.get("volume", 0))),
                time=time_val,
            ))
        except (ValueError, TypeError) as e:
            logger.debug("Skipping row due to parse error: %s", e)
            continue

    return prices


# ═══════════════════════════════════════════════
# Financial metrics
# ═══════════════════════════════════════════════

def get_financial_metrics(
    ticker: str,
    end_date: str,
    period: str = "ttm",
    limit: int = 10,
) -> list[FinancialMetrics]:
    """
    Fetch key financial metrics for a CN/HK stock.

    Maps AKShare financial indicator data to the FinancialMetrics model
    used by the existing analyst agents.
    """
    cache_key = f"cn_metrics_{ticker}_{period}_{end_date}_{limit}"
    if cached := _cache.get_financial_metrics(cache_key):
        return [FinancialMetrics(**m) for m in cached]

    ak = _ensure_akshare()
    info = parse_ticker(ticker)

    try:
        if info.market.is_china:
            metrics = _fetch_cn_financial_metrics(ak, info, end_date, limit)
        elif info.market.is_hk:
            metrics = _fetch_hk_financial_metrics(ak, info, end_date, limit)
        else:
            return []
    except Exception as e:
        logger.warning("Failed to fetch financial metrics for %s: %s", ticker, e)
        return []

    if not metrics:
        return []

    _cache.set_financial_metrics(cache_key, [m.model_dump() for m in metrics])
    return metrics


def _fetch_cn_financial_metrics(
    ak, info: TickerInfo, end_date: str, limit: int
) -> list[FinancialMetrics]:
    """Fetch A-share financial indicators and map to FinancialMetrics."""
    metrics_list = []

    try:
        # 主要财务指标
        df_indicator = ak.stock_financial_analysis_indicator(
            symbol=info.code, start_year="2020"
        )
    except Exception as e:
        logger.warning("stock_financial_analysis_indicator failed for %s: %s", info.code, e)
        return []

    if df_indicator is None or df_indicator.empty:
        return []

    # Filter by end_date and limit
    end_dt = datetime.datetime.strptime(end_date, "%Y-%m-%d")

    for _, row in df_indicator.head(limit).iterrows():
        try:
            report_date = str(row.get("日期", ""))
            if hasattr(row.get("日期"), "strftime"):
                report_date = row["日期"].strftime("%Y-%m-%d")

            metrics_list.append(FinancialMetrics(
                ticker=info.full_ticker,
                report_period=report_date,
                period="ttm",
                currency="CNY",
                market_cap=_safe_float(row.get("总市值")),
                enterprise_value=None,
                price_to_earnings_ratio=_safe_float(row.get("市盈率")),
                price_to_book_ratio=_safe_float(row.get("市净率")),
                price_to_sales_ratio=None,
                enterprise_value_to_ebitda_ratio=None,
                enterprise_value_to_revenue_ratio=None,
                free_cash_flow_yield=None,
                peg_ratio=None,
                gross_margin=_safe_float(row.get("销售毛利率")),
                operating_margin=None,
                net_margin=_safe_float(row.get("销售净利率")),
                return_on_equity=_safe_float(row.get("净资产收益率")),
                return_on_assets=_safe_float(row.get("总资产收益率")),
                return_on_invested_capital=None,
                asset_turnover=_safe_float(row.get("总资产周转率")),
                inventory_turnover=_safe_float(row.get("存货周转率")),
                receivables_turnover=_safe_float(row.get("应收账款周转率")),
                days_sales_outstanding=None,
                operating_cycle=None,
                working_capital_turnover=None,
                current_ratio=_safe_float(row.get("流动比率")),
                quick_ratio=_safe_float(row.get("速动比率")),
                cash_ratio=None,
                operating_cash_flow_ratio=None,
                debt_to_equity=_safe_float(row.get("资产负债率")),
                debt_to_assets=None,
                interest_coverage=None,
                revenue_growth=_safe_float(row.get("营业收入增长率")),
                earnings_growth=_safe_float(row.get("净利润增长率")),
                book_value_growth=None,
                earnings_per_share_growth=None,
                free_cash_flow_growth=None,
                operating_income_growth=None,
                ebitda_growth=None,
                payout_ratio=None,
                earnings_per_share=_safe_float(row.get("基本每股收益")),
                book_value_per_share=_safe_float(row.get("每股净资产")),
                free_cash_flow_per_share=None,
            ))
        except Exception as e:
            logger.debug("Skipping metrics row: %s", e)
            continue

    return metrics_list


def _fetch_hk_financial_metrics(
    ak, info: TickerInfo, end_date: str, limit: int
) -> list[FinancialMetrics]:
    """Fetch HK stock financial metrics. HK data is sparser in AKShare."""
    # For HK stocks, we use a simpler approach with available data
    try:
        df = ak.stock_hk_spot_em()
        row = df[df["代码"] == info.code]
        if row.empty:
            return []
        row = row.iloc[0]

        return [FinancialMetrics(
            ticker=info.full_ticker,
            report_period=end_date,
            period="ttm",
            currency="HKD",
            market_cap=_safe_float(row.get("总市值")),
            enterprise_value=None,
            price_to_earnings_ratio=_safe_float(row.get("市盈率")),
            price_to_book_ratio=_safe_float(row.get("市净率")),
            price_to_sales_ratio=None,
            enterprise_value_to_ebitda_ratio=None,
            enterprise_value_to_revenue_ratio=None,
            free_cash_flow_yield=None,
            peg_ratio=None,
            gross_margin=None, operating_margin=None, net_margin=None,
            return_on_equity=None, return_on_assets=None,
            return_on_invested_capital=None, asset_turnover=None,
            inventory_turnover=None, receivables_turnover=None,
            days_sales_outstanding=None, operating_cycle=None,
            working_capital_turnover=None, current_ratio=None,
            quick_ratio=None, cash_ratio=None, operating_cash_flow_ratio=None,
            debt_to_equity=None, debt_to_assets=None, interest_coverage=None,
            revenue_growth=None, earnings_growth=None, book_value_growth=None,
            earnings_per_share_growth=None, free_cash_flow_growth=None,
            operating_income_growth=None, ebitda_growth=None,
            payout_ratio=None, earnings_per_share=None,
            book_value_per_share=None, free_cash_flow_per_share=None,
        )]
    except Exception as e:
        logger.warning("HK financial metrics failed for %s: %s", info.code, e)
        return []


# ═══════════════════════════════════════════════
# Company news
# ═══════════════════════════════════════════════

def get_company_news(
    ticker: str,
    end_date: str,
    start_date: str | None = None,
    limit: int = 100,
) -> list[CompanyNews]:
    """Fetch company news for a CN/HK stock via AKShare + 东方财富."""
    cache_key = f"cn_news_{ticker}_{start_date or 'none'}_{end_date}_{limit}"
    if cached := _cache.get_company_news(cache_key):
        return [CompanyNews(**n) for n in cached]

    ak = _ensure_akshare()
    info = parse_ticker(ticker)

    try:
        df = ak.stock_news_em(symbol=info.code)
    except Exception as e:
        logger.warning("Failed to fetch news for %s: %s", ticker, e)
        return []

    if df is None or df.empty:
        return []

    news_list = []
    end_dt = datetime.datetime.strptime(end_date, "%Y-%m-%d")
    start_dt = (
        datetime.datetime.strptime(start_date, "%Y-%m-%d")
        if start_date else end_dt - datetime.timedelta(days=30)
    )

    for _, row in df.iterrows():
        try:
            pub_date = str(row.get("发布时间", ""))
            if hasattr(row.get("发布时间"), "strftime"):
                pub_date = row["发布时间"].strftime("%Y-%m-%d %H:%M:%S")

            # Filter by date range
            date_part = pub_date[:10]
            if date_part > end_date or date_part < start_dt.strftime("%Y-%m-%d"):
                continue

            news_list.append(CompanyNews(
                ticker=info.full_ticker,
                title=str(row.get("新闻标题", "")),
                author=None,
                source=str(row.get("文章来源", "东方财富")),
                date=pub_date,
                url=str(row.get("新闻链接", "")),
                sentiment=None,  # Will be classified by LLM
            ))
        except Exception as e:
            logger.debug("Skipping news row: %s", e)
            continue

    news_list = news_list[:limit]

    if news_list:
        _cache.set_company_news(cache_key, [n.model_dump() for n in news_list])
    return news_list


# ═══════════════════════════════════════════════
# Market cap
# ═══════════════════════════════════════════════

def get_market_cap(ticker: str, end_date: str) -> float | None:
    """Fetch current market capitalization for a CN/HK stock."""
    ak = _ensure_akshare()
    info = parse_ticker(ticker)

    try:
        if info.market.is_china:
            df = ak.stock_zh_a_spot_em()
            row = df[df["代码"] == info.code]
            if not row.empty:
                return _safe_float(row.iloc[0].get("总市值"))
        elif info.market.is_hk:
            df = ak.stock_hk_spot_em()
            row = df[df["代码"] == info.code]
            if not row.empty:
                return _safe_float(row.iloc[0].get("总市值"))
    except Exception as e:
        logger.warning("Failed to fetch market cap for %s: %s", ticker, e)

    return None


# ═══════════════════════════════════════════════
# China-specific data: capital flow
# ═══════════════════════════════════════════════

def get_northbound_flow(
    start_date: str | None = None,
    end_date: str | None = None,
    limit: int = 30,
) -> list[NorthboundFlow]:
    """Fetch 北向资金 (northbound capital flow) daily data."""
    ak = _ensure_akshare()

    # AKShare has renamed this API across versions — try known names in order
    df = None
    for fn_name, kwargs in [
        ("stock_hsgt_fund_flow_summary_em", {}),
        ("stock_hsgt_north_net_flow_in_em", {"symbol": "北上"}),
        ("stock_hsgt_hist_em", {"symbol": "北向资金"}),
    ]:
        fn = getattr(ak, fn_name, None)
        if fn is None:
            continue
        try:
            df = fn(**kwargs)
            if df is not None and not df.empty:
                break
        except Exception as e:
            logger.debug("Northbound API %s failed: %s", fn_name, e)
            continue

    if df is None or df.empty:
        logger.warning("All northbound flow APIs failed; returning empty list")
        return []

    flows = []
    for _, row in df.tail(limit).iterrows():
        try:
            date_val = str(row.get("日期", ""))
            if hasattr(row.get("日期"), "strftime"):
                date_val = row["日期"].strftime("%Y-%m-%d")

            flows.append(NorthboundFlow(
                date=date_val,
                total_net_buy=_safe_float(row.get("当日净买入", row.get("净买入"))),
            ))
        except Exception as e:
            logger.debug("Skipping northbound flow row: %s", e)
            continue

    return flows


def get_margin_trading(
    ticker: str | None = None,
    limit: int = 30,
) -> list[MarginTrading]:
    """Fetch 融资融券 data (market-wide or per-stock)."""
    ak = _ensure_akshare()

    try:
        if ticker:
            info = parse_ticker(ticker)
            df = ak.stock_margin_detail_sse(symbol=info.code)
        else:
            df = ak.stock_margin_sse(start_date="20240101")
    except Exception as e:
        logger.warning("Failed to fetch margin trading data: %s", e)
        return []

    if df is None or df.empty:
        return []

    results = []
    for _, row in df.tail(limit).iterrows():
        try:
            date_val = str(row.get("信用交易日期", row.get("日期", "")))
            if hasattr(date_val, "strftime"):
                date_val = date_val.strftime("%Y-%m-%d")

            results.append(MarginTrading(
                date=date_val[:10] if len(date_val) >= 10 else date_val,
                ticker=ticker,
                margin_balance=_safe_float(row.get("融资余额")),
                margin_buy=_safe_float(row.get("融资买入额")),
                short_balance=_safe_float(row.get("融券余额")),
            ))
        except Exception as e:
            logger.debug("Skipping margin row: %s", e)
            continue

    return results


def get_main_capital_flow(
    ticker: str,
    limit: int = 30,
) -> list[MainCapitalFlow]:
    """Fetch 主力资金流向 (main capital flow) for a specific stock."""
    ak = _ensure_akshare()
    info = parse_ticker(ticker)

    try:
        df = ak.stock_individual_fund_flow(stock=info.code, market=info.exchange.lower())
    except Exception as e:
        logger.warning("Failed to fetch capital flow for %s: %s", ticker, e)
        return []

    if df is None or df.empty:
        return []

    results = []
    for _, row in df.tail(limit).iterrows():
        try:
            date_val = str(row.get("日期", ""))
            if hasattr(row.get("日期"), "strftime"):
                date_val = row["日期"].strftime("%Y-%m-%d")

            results.append(MainCapitalFlow(
                date=date_val,
                ticker=info.full_ticker,
                main_net_inflow=_safe_float(row.get("主力净流入-净额")),
                super_large_net=_safe_float(row.get("超大单净流入-净额")),
                large_net=_safe_float(row.get("大单净流入-净额")),
                medium_net=_safe_float(row.get("中单净流入-净额")),
                small_net=_safe_float(row.get("小单净流入-净额")),
            ))
        except Exception as e:
            logger.debug("Skipping capital flow row: %s", e)
            continue

    return results


# ═══════════════════════════════════════════════
# China-specific data: sector / concept
# ═══════════════════════════════════════════════

def get_sector_performance(limit: int = 30) -> list[SectorPerformance]:
    """Fetch 板块行情 (sector performance) for rotation analysis."""
    ak = _ensure_akshare()

    try:
        df = ak.stock_board_industry_name_em()
    except Exception as e:
        logger.warning("Failed to fetch sector performance: %s", e)
        return []

    if df is None or df.empty:
        return []

    today = datetime.datetime.now().strftime("%Y-%m-%d")
    results = []
    for _, row in df.head(limit).iterrows():
        try:
            results.append(SectorPerformance(
                date=today,
                sector_name=str(row.get("板块名称", "")),
                change_pct=_safe_float(row.get("涨跌幅")),
                turnover_rate=_safe_float(row.get("换手率")),
                leading_stock=str(row.get("领涨股票", "")),
                stock_count_up=_safe_int(row.get("上涨家数")),
                stock_count_down=_safe_int(row.get("下跌家数")),
            ))
        except Exception as e:
            logger.debug("Skipping sector row: %s", e)
            continue

    return results


def get_stock_sector_info(ticker: str) -> SectorInfo | None:
    """Get sector and concept membership for a stock."""
    ak = _ensure_akshare()
    info = parse_ticker(ticker)

    try:
        # 所属行业
        df = ak.stock_board_industry_cons_em(symbol="")
        industry = None
        concepts = []

        # Try individual stock info
        df_info = ak.stock_individual_info_em(symbol=info.code)
        if df_info is not None and not df_info.empty:
            for _, row in df_info.iterrows():
                item = str(row.get("item", ""))
                value = str(row.get("value", ""))
                if "行业" in item:
                    industry = value

        return SectorInfo(
            ticker=info.full_ticker,
            industry=industry,
            concepts=concepts,
        )
    except Exception as e:
        logger.warning("Failed to fetch sector info for %s: %s", ticker, e)
        return None


# ═══════════════════════════════════════════════
# Public opinion data
# ═══════════════════════════════════════════════

def get_public_opinion(
    ticker: str | None = None,
    limit: int = 50,
) -> list[PublicOpinionItem]:
    """
    Fetch public opinion data from multiple sources.

    Currently sources from 东方财富 stock news.
    Designed to be extended with additional sources
    (财联社, 雪球, 微博) via plugins.
    """
    ak = _ensure_akshare()
    results = []

    # Source 1: 东方财富 individual stock news
    if ticker:
        info = parse_ticker(ticker)
        try:
            df = ak.stock_news_em(symbol=info.code)
            if df is not None and not df.empty:
                for _, row in df.head(limit).iterrows():
                    try:
                        pub_date = str(row.get("发布时间", ""))
                        if hasattr(row.get("发布时间"), "strftime"):
                            pub_date = row["发布时间"].strftime("%Y-%m-%d %H:%M:%S")

                        results.append(PublicOpinionItem(
                            date=pub_date,
                            source="东方财富",
                            title=str(row.get("新闻标题", "")),
                            content=str(row.get("新闻内容", ""))[:500],
                            url=str(row.get("新闻链接", "")),
                        ))
                    except Exception:
                        continue
        except Exception as e:
            logger.warning("Failed to fetch stock news for opinion: %s", e)

    # Source 2: Market-wide financial news (财经快讯)
    try:
        df_cls = ak.stock_info_global_em()
        if df_cls is not None and not df_cls.empty:
            for _, row in df_cls.head(20).iterrows():
                try:
                    results.append(PublicOpinionItem(
                        date=str(row.get("发布时间", ""))[:19],
                        source="东方财富全球资讯",
                        title=str(row.get("标题", row.get("新闻标题", ""))),
                        content=str(row.get("内容", ""))[:500],
                    ))
                except Exception:
                    continue
    except Exception as e:
        logger.debug("Global news fetch failed: %s", e)

    return results[:limit]


# ═══════════════════════════════════════════════
# Utility: DataFrame conversion
# ═══════════════════════════════════════════════

def prices_to_df(prices: list[Price]) -> pd.DataFrame:
    """Convert prices to a DataFrame (same interface as api.py)."""
    df = pd.DataFrame([p.model_dump() for p in prices])
    df["Date"] = pd.to_datetime(df["time"])
    df.set_index("Date", inplace=True)
    numeric_cols = ["open", "close", "high", "low", "volume"]
    for col in numeric_cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
    df.sort_index(inplace=True)
    return df


def get_price_data(ticker: str, start_date: str, end_date: str) -> pd.DataFrame:
    """Get price data as DataFrame (same interface as api.py)."""
    prices = get_prices(ticker, start_date, end_date)
    return prices_to_df(prices)


# ═══════════════════════════════════════════════
# Internal helpers
# ═══════════════════════════════════════════════

def _safe_float(val) -> float | None:
    """Safely convert a value to float, returning None on failure."""
    if val is None or (isinstance(val, str) and val.strip() in ("", "-", "--", "NaN")):
        return None
    try:
        result = float(val)
        if pd.isna(result):
            return None
        return result
    except (ValueError, TypeError):
        return None


def _safe_int(val) -> int | None:
    """Safely convert a value to int."""
    f = _safe_float(val)
    return int(f) if f is not None else None
