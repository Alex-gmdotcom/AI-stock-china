</div><div id="single-msg"></div></div>

<div class="sec"><h3>自选池(弹性,不受 5+5+5 约束)</h3>
<div class="watch">${(POOL.watchlist||[]).map(e=>`<span class="w">${esc(e.name)} <span class="tk">${esc(e.ticker)}</span></span>`).join('')||'<span class="gap">空</span>'}</div></div>

<div class="foot">迁移信号红黄灯 = ${Object.keys(SIGNALS).length?Object.keys(SIGNALS).length+' 条':'<span style="color:var(--e8b339)">信号引擎待建(detect_migration_signals 未实现);T→V / N→T 依赖资金流数据,现为【数据缺口】</span>'}
<br>所有操作人工触发(I4.3)· 月配额按 pair_id 去重(I4.2)· 池状态 .tmp+rename+7天backup(I4.4)</div>`;
wire();
}
function wire(){
document.querySelectorAll('.cell').forEach(c=>c.onclick=()=>{
const e={ticker:c.dataset.tk,name:c.dataset.nm,category:c.dataset.cat};
if(SEL.exit&&SEL.exit.ticker===e.ticker){SEL.exit=null;}
else if(SEL.enter&&SEL.enter.ticker===e.ticker){SEL.enter=null;}
else if(!SEL.exit){SEL.exit=e;}
else if(!SEL.enter){SEL.enter=e;}
render();});
const rm=document.getElementById('rm-tk');
if(rm)rm.innerHTML=[...POOL.v_pool,...POOL.t_pool,...POOL.n_pool]
.map(e=>`<option value="${esc(e.ticker)}">${esc(e.name)} (${esc(e.ticker)}) · ${esc(e.category)}</option>`).join('');
// evidence 模板
const t=document.getElementById('tmpl');
if(t){const cat=SEL.enter?SEL.enter.category:(SEL.exit?SEL.exit.category:'V');
const keys=[...(EVID_TMPL[cat]||[]),...EVID_TMPL.RISK];
t.innerHTML=keys.map(k=>`<button data-k="${esc(k)}">+ ${esc(k)}</button>`).join('');
t.querySelectorAll('button').forEach(b=>b.onclick=()=>{const ta=document.getElementById('rationale');
var NL=String.fromCharCode(10);ta.value=(ta.value?ta.value.trimEnd()+NL:'')+'· '+b.dataset.k;ta.focus();});}
// 提交闸门
const btn=document.getElementById('btn-mig'),why=document.getElementById('mig-why');
function gate(){const hasEnter=!!SEL.enter;
const ra=(document.getElementById('rationale')||{}).value||'';
const q=POOL.monthly_migrations_used>=POOL.monthly_migrations_limit;
let msg='';
if(q)msg='本月配额已用尽(I4.2)';
else if(!SEL.exit)msg='需选出腿';
else if(!hasEnter)msg='需选入腿(池内另一只票)';
else if(SEL.exit.category===SEL.enter.category)msg='两腿同类无意义(净变化须为 0,需方向互补)';
else if(!ra.trim())msg='迁移理由必填(I4.5)';
btn.disabled=!!msg;why.textContent=msg;}
['rationale'].forEach(id=>{const el=document.getElementById(id);if(el)el.oninput=gate,el.onchange=gate;});
gate();
document.getElementById('btn-clear').onclick=()=>{SEL={exit:null,enter:null};render();};
btn.onclick=async()=>{
const exitTo=(document.getElementById('exit-to')||{}).value;
const enterLeg={ticker:SEL.enter.ticker,name:SEL.enter.name,from_category:SEL.enter.category,
to_category:(document.getElementById('enter-to')||{}).value};
btn.disabled=true;
const body={exit_leg:{ticker:SEL.exit.ticker,name:SEL.exit.name,from_category:SEL.exit.category,to_category:exitTo},
enter_leg:enterLeg,user_rationale:document.getElementById('rationale').value};
post('/api/pool/migrate',body,'mig-msg',()=>{SEL={exit:null,enter:null};});
};
const ba=document.getElementById('btn-add');
if(ba)ba.onclick=()=>post('/api/pool/add',{ticker:document.getElementById('add-tk').value,
name:document.getElementById('add-nm').value,category:document.getElementById('add-cat').value,
rationale:document.getElementById('add-why').value},'single-msg');
const br=document.getElementById('btn-rm');
if(br)br.onclick=()=>post('/api/pool/remove',{ticker:document.getElementById('rm-tk').value,
rationale:document.getElementById('rm-why').value},'single-msg');
}
async function post(url,body,msgId,onOk){
const box=document.getElementById(msgId);box.innerHTML='<div class="hint">提交中…</div>';
try{const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
const d=await r.json();
if(!r.ok){box.innerHTML=`<div class="msg err"><b>${esc(d.error||'失败')}</b><br>${esc(d.message||'')}</div>`;
if(document.getElementById('btn-mig'))document.getElementById('btn-mig').disabled=false;return;}
box.innerHTML=`<div class="msg ok">✓ ${esc(d.message||'成功')}</div>`;
if(onOk)onOk();
const r2=await fetch('/api/pool');POOL=await r2.json();render();
}catch(e){box.innerHTML=`<div class="msg err">${esc(e.message)}</div>`;}
}
boot();
</script></body></html>
"""


# ────────────────────────────────────────────────────────────
# marker: STEP18_POOL_PAGE_V2 — 池总览页 + 配对迁移 API(TECH §10.3;I4.1-I4.5)
# ────────────────────────────────────────────────────────────

_POOL_PERF_CACHE: dict = {"at": 0.0, "data": None}
_POOL_PERF_TTL = 900  # 15 分钟(池总览非高频页;15 只票串行 baostock 首次约 1-2 分钟)


class _MigLegIn(BaseModel):
    ticker: str
    name: str = ""
    from_category: str
    to_category: str


class _MigrateIn(BaseModel):
    exit_leg: _MigLegIn
    enter_leg: _MigLegIn
    user_rationale: str


class _AddIn(BaseModel):
    ticker: str
    name: str = ""
    category: str
    rationale: str


class _RemoveIn(BaseModel):
    ticker: str
    rationale: str = ""


def _import_tc():
    """裁决④:进程内已加载实例优先,兜底 tools/strategy 优先(避免双模块实例)。"""
    import sys as _sys
    m = _sys.modules.get("strategy.three_categories") or _sys.modules.get("src.strategy.three_categories")
    if m is not None:
        return m
    try:
        from strategy import three_categories as m
    except ImportError:
        from src.strategy import three_categories as m
    return m


def _pool_err(exc: Exception, status: int = 400):
    """池异常 → 结构化 HTTP(R5a-R5d 的用户可见面)。"""
    return JSONResponse({"error": type(exc).__name__, "message": str(exc)},
                        status_code=status)


@app.get("/pool")
def pool_page():
    """三分法池总览页(热力图 + 配对迁移双腿面板)。"""
    return HTMLResponse(_POOL_PAGE_HTML)


@app.get("/api/pool/perf")
def pool_perf(refresh: int = 0):
    """池内 15 只票 5日/20日涨跌 + 迁移信号(TTL 缓存)。

    失败个股置 None(I1.1:不以 0 冒充);整体失败不阻塞热力图。
    signals 暂空——detect_migration_signals 未实现(TECH §10.2 待建),
    不给假红黄灯。
    """
    import time as _t
    now = _t.time()
    if not refresh and _POOL_PERF_CACHE["data"] is not None \
            and now - _POOL_PERF_CACHE["at"] < _POOL_PERF_TTL:
        return {**_POOL_PERF_CACHE["data"], "cached": True}

    _tcm = _import_tc()
    pool = _tcm.ThreeCategoryPool()
    j = pool.to_json_for_frontend()
    tickers = [e["ticker"] for k in ("v_pool", "t_pool", "n_pool") for e in j.get(k, [])]

    perf: dict = {}
    for tk in tickers:
        try:
            perf[tk] = _pool_one_perf(tk)
        except Exception as e:                       # fail-soft,单票失败不拖垮整页
            print(f"[pool_perf] {tk} 失败: {e}")
            perf[tk] = {"ret_5d": None, "ret_20d": None, "error": str(e)[:80]}

    out = {"perf": perf, "signals": {}, "cached": False,
           "note": "signals 空:detect_migration_signals 未实现;T→V/N→T 依赖资金流(当前【数据缺口】)"}
    _POOL_PERF_CACHE.update({"at": now, "data": out})
    return out


def _pool_one_perf(ticker: str) -> dict:
    """单票 5日/20日累计涨跌 %(经既有取价链;拿不到 → None,不补 0)。"""
    from datetime import date, timedelta
    # 裁决④:进程内已加载实例优先 → 兜底 tools 优先(与 api_china 导入序对齐)
    import sys as _sys
    _api = _sys.modules.get("tools.api") or _sys.modules.get("src.tools.api")
    if _api is None:
        try:
            from tools import api as _api           # tools 优先
        except ImportError:
            from src.tools import api as _api
    get_prices = _api.get_prices
    end = date.today()
    start = end - timedelta(days=60)
    rows = get_prices(ticker, start.isoformat(), end.isoformat())
    closes = []
    for r in (rows or []):
        c = getattr(r, "close", None)
        if c is None and isinstance(r, dict):
            c = r.get("close")
        if c is not None:
            closes.append(float(c))
    def _ret(n: int):
        if len(closes) < n + 1 or not closes[-(n + 1)]:
            return None
        return round((closes[-1] / closes[-(n + 1)] - 1) * 100, 2)
    return {"ret_5d": _ret(5), "ret_20d": _ret(20), "n_bars": len(closes)}


@app.post("/api/pool/migrate")
def pool_migrate(req: _MigrateIn):
    """配对原子迁移(两腿;任一腿失败整体拒绝,不产生半迁移态)。

    真实签名(2026-07-09 preflight 实测):
        execute_migration_pair(state, exit_leg, enter_leg, user_rationale,
                               dir_override=None) -> PoolState   # 内部已写盘
        MigrationLeg(ticker, from_category, to_category, signal='manual', evidence=[])
    约束:两腿方向必须互补(V/T/N 各池净变化 = 0);当前实现不支持 OUT(池外腿)。
    """
    tc = _import_tc()
    try:
        if not (req.user_rationale or "").strip():
            raise tc.MissingMigrationRationale("迁移理由必填(I4.5)")
        for lg in (req.exit_leg, req.enter_leg):
            if lg.from_category == "OUT" or lg.to_category == "OUT":
                return JSONResponse(
                    {"error": "OutLegNotSupported",
                     "message": "当前 execute_migration_pair 仅支持池内 V/T/N 三类互迁,"
                                "不支持 OUT(池外腿)。进出池请用单票 加池/减池,"
                                "或等待 OUT 支持补丁(TECH §10.3 规格已含 OUT,实现待补)。"},
                    status_code=400)
        state = tc.load_pool_state()
        ev = [{"source": "web_ui", "manual": True}]
        exit_leg = tc.MigrationLeg(ticker=req.exit_leg.ticker,
                                   from_category=req.exit_leg.from_category,
                                   to_category=req.exit_leg.to_category,
                                   signal="manual", evidence=ev)
        enter_leg = tc.MigrationLeg(ticker=req.enter_leg.ticker,
                                    from_category=req.enter_leg.from_category,
                                    to_category=req.enter_leg.to_category,
                                    signal="manual", evidence=ev)
        # 内部自行写盘(.tmp + rename + backup),此处不得重复 save(避免双写污染备份轮转)
        tc.execute_migration_pair(state, exit_leg, enter_leg,
                                  user_rationale=req.user_rationale)
        _POOL_PERF_CACHE["data"] = None
        return {"ok": True,
                "message": f"配对迁移完成:{req.exit_leg.ticker} {req.exit_leg.from_category}→{req.exit_leg.to_category} / "
                           f"{req.enter_leg.ticker} {req.enter_leg.from_category}→{req.enter_leg.to_category}"}
    except (tc.MonthlyMigrationLimitExceeded, tc.PoolSizeInvariantViolated,
            tc.MissingMigrationRationale, tc.DuplicateTickerError,
            tc.PoolNotFoundError) as e:
        return _pool_err(e, 400)
    except Exception as e:
        return _pool_err(e, 500)


@app.post("/api/pool/add")
def pool_add(req: _AddIn):
    """单票加池(目标类未满员才允许;满员必须走配对迁移)。

    真实签名:add_initial_entry(state, entry: PoolEntry, *, persist=True, dir_override=None)
    persist=True 时内部写盘,此处不重复 save。
    注:add_initial_entry 本身不校验满员;5+5+5 由 save_pool_state 的断言把关,
       此处显式前置校验以给出可读错误(R5c)。
    """
    tc = _import_tc()
    try:
        if not (req.rationale or "").strip():
            raise tc.MissingMigrationRationale("加池理由必填(I4.5)")
        if req.category not in ("V", "T", "N"):
            raise ValueError(f"category 必须是 V/T/N,得到 {req.category}")
        state = tc.load_pool_state()
        pool = {"V": state.v_pool, "T": state.t_pool, "N": state.n_pool}[req.category]
        if len(pool) >= 5:
            raise tc.PoolSizeInvariantViolated(
                f"{req.category} 类已满员(5/5),不能单票加入(I4.1)。请走配对迁移,"
                f"或先移出一只。")
        from datetime import datetime as _dt
        entry = tc.PoolEntry(ticker=req.ticker, name=req.name or req.ticker,
                             category=req.category, sub_id="",
                             rationale=req.rationale,
                             added_at=_dt.now().isoformat())
        tc.add_initial_entry(state, entry)      # persist=True 内部写盘
        _POOL_PERF_CACHE["data"] = None
        return {"ok": True, "message": f"{req.ticker} 已加入 {req.category} 类"}
    except (tc.PoolSizeInvariantViolated, tc.DuplicateTickerError,
            tc.MissingMigrationRationale) as e:
        return _pool_err(e, 400)
    except Exception as e:
        return _pool_err(e, 500)


@app.post("/api/pool/remove")
def pool_remove(req: _RemoveIn):
    """单票减池(persist=True 内部写盘,此处不重复 save)。

    注:移出后该类 <5,save_pool_state 的 5+5+5 断言可能拒绝。
       若被拒 → 说明必须走配对迁移而非单票操作。
    """
    tc = _import_tc()
    try:
        state = tc.load_pool_state()
        tc.remove_entry(state, req.ticker)      # persist=True 内部写盘
        _POOL_PERF_CACHE["data"] = None
        return {"ok": True, "message": f"{req.ticker} 已移出池"}
    except (tc.PoolNotFoundError, tc.PoolSizeInvariantViolated) as e:
        return _pool_err(e, 400)
    except Exception as e:
        return _pool_err(e, 500)


