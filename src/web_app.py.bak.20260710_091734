/* ══ K线 canvas ══ */
let KROWS=[],KPERIOD='D';
function renderKline(mnt,kd){
KROWS=(kd.rows||[]).slice().sort((a,b)=>String(a.t)<String(b.t)?-1:1);
if(!KROWS.length){mnt.innerHTML='<div class="gap">【数据缺口】K线无行</div>';return;}
mnt.innerHTML=`<div style="display:flex"><span class="kbar">
<button data-p="D" class="on">日</button><button data-p="W">周</button><button data-p="M">月</button></span></div>
<canvas id="kcv" height="360"></canvas><div class="kread" id="kread">移动到 K 线查看当日 OHLC</div>`;
mnt.querySelectorAll('.kbar button').forEach(b=>b.onclick=()=>{KPERIOD=b.dataset.p;
mnt.querySelectorAll('.kbar button').forEach(x=>x.classList.toggle('on',x===b));drawK();});
const cv=document.getElementById('kcv');
cv.addEventListener('mousemove',e=>{if(!cv._geo)return;const r=cv.getBoundingClientRect();
const i=Math.round((e.clientX-r.left-cv._geo.padL)/cv._geo.cw-0.5);if(i<0||i>=cv._geo.rows.length)return;
const k=cv._geo.rows[i],col=k.c>=k.o?'up':'down';
document.getElementById('kread').innerHTML=`<b>${k.t}</b>　开 <b class="${col}">${num(k.o)}</b>　高 ${num(k.h)}　低 ${num(k.l)}　收 <b class="${col}">${num(k.c)}</b>　量 ${k.v!=null?(k.v/1e4).toFixed(0)+'万':'—'}`;});
requestAnimationFrame(drawK);
}
function aggK(rows,sz){if(sz<=1)return rows;const o=[];for(let i=0;i<rows.length;i+=sz){const g=rows.slice(i,i+sz);if(!g.length)break;
o.push({t:g[g.length-1].t,o:g[0].o,c:g[g.length-1].c,h:Math.max(...g.map(x=>x.h)),l:Math.min(...g.map(x=>x.l)),
v:g.reduce((s,x)=>s+(x.v||0),0),ma5:null,ma20:null,ma60:null});}return o;}
function maCalc(rows,w){return rows.map((_,i)=>i<w-1?null:+(rows.slice(i-w+1,i+1).reduce((s,k)=>s+k.c,0)/w).toFixed(3));}
function drawK(){
const cv=document.getElementById('kcv');if(!cv)return;
const sz=KPERIOD==='D'?1:KPERIOD==='W'?5:21;
const rows=aggK(KROWS,sz);
const ma={5:sz===1?rows.map(r=>r.ma5):maCalc(rows,5),20:sz===1?rows.map(r=>r.ma20):maCalc(rows,20),60:sz===1?rows.map(r=>r.ma60):maCalc(rows,60)};
const dpr=devicePixelRatio||1,W=cv.clientWidth,H=360;cv.width=W*dpr;cv.height=H*dpr;
const g=cv.getContext('2d');g.setTransform(dpr,0,0,dpr,0,0);g.clearRect(0,0,W,H);
const padL=52,padR=12,padT=16,priceH=H*0.70,volTop=priceH+16,volH=H-volTop-14,n=rows.length;
let mn=Math.min(...rows.map(k=>k.l)),mx=Math.max(...rows.map(k=>k.h));
[5,20,60].forEach(w=>ma[w].forEach(v=>{if(v!=null){mn=Math.min(mn,v);mx=Math.max(mx,v);}}));
const rg=(mx-mn)||1;mn-=rg*0.04;mx+=rg*0.04;
const cw=(W-padL-padR)/n,xC=i=>padL+cw*(i+0.5),yP=v=>padT+(1-(v-mn)/(mx-mn))*(priceH-padT);
g.strokeStyle='#1a2130';g.fillStyle=CDIM;g.font='10px '+cssv('--mono');g.textAlign='right';g.textBaseline='middle';
for(let s=0;s<=4;s++){const v=mn+(mx-mn)*s/4,y=yP(v);g.beginPath();g.moveTo(padL,y);g.lineTo(W-padR,y);g.stroke();g.fillText(v.toFixed(2),padL-6,y);}
const vmax=Math.max(...rows.map(k=>k.v||0))||1;
rows.forEach((k,i)=>{const up=k.c>=k.o;g.fillStyle=up?CUP:CDOWN;g.globalAlpha=.5;const bh=(k.v||0)/vmax*volH;
g.fillRect(xC(i)-cw*0.32,volTop+volH-bh,cw*0.64,bh);g.globalAlpha=1;});
rows.forEach((k,i)=>{const up=k.c>=k.o,col=up?CUP:CDOWN,x=xC(i);g.strokeStyle=col;g.fillStyle=col;g.lineWidth=1;
g.beginPath();g.moveTo(x,yP(k.h));g.lineTo(x,yP(k.l));g.stroke();
const yo=yP(k.o),yc=yP(k.c),top=Math.min(yo,yc),bh=Math.max(1,Math.abs(yo-yc));g.fillRect(x-cw*0.3,top,cw*0.6,bh);});
const mc={5:'#e8b339',20:'#5b7cfa',60:'#b57bff'};
[5,20,60].forEach(w=>{g.strokeStyle=mc[w];g.lineWidth=1.3;g.beginPath();let pen=false;
ma[w].forEach((v,i)=>{if(v==null){pen=false;return;}const x=xC(i),y=yP(v);if(!pen){g.moveTo(x,y);pen=true;}else g.lineTo(x,y);});g.stroke();});
g.textAlign='left';let lx=padL;[['MA5',mc[5]],['MA20',mc[20]],['MA60',mc[60]]].forEach(([t,cl])=>{g.fillStyle=cl;g.fillText(t,lx,8);lx+=g.measureText(t).width+14;});
cv._geo={rows,xC,cw,padL};
}

/* ══ 资金面 sparkline(真字段;None 不补 0,I1.1) ══ */
// 真实元素形状(2026-07-08 探针实测):
//   northbound: {date, total_net_buy, sh_net_buy, sz_net_buy}   ← 常全 None(壳在肉无)
//   margin:     {date, margin_balance, short_balance, total_balance}
//   main_flow:  东财 drop 时空数组
const CAPSPEC=[
 ["北向净买入","northbound",["total_net_buy","net_buy","value"]],
 ["融资余额","margin",["margin_balance","total_balance","value"]],
 ["主力净额","main_flow",["net_amount","main_net","value"]]];
function pickVal(o,keys){if(o==null)return null;
if(Array.isArray(o))return o[1]==null?null:+o[1];
if(typeof o!=="object")return +o;
for(const k of keys){if(o[k]!=null&&!Number.isNaN(+o[k]))return +o[k];}return null;}
function renderCapital(mnt,cap){
mnt.innerHTML='<div class="sprow">'+CAPSPEC.map(([lab,key,keys])=>{
const arr=cap[key];
if(!arr||!arr.length)return `<div class="spk gapd gap">${lab}<br>【数据缺口】</div>`;
const vals=arr.map(x=>pickVal(x,keys));
const good=vals.filter(v=>v!=null);
// 全 None = 有壳无肉 → 数据缺口,绝不画 0 线(I1.1 / R2)
if(!good.length)return `<div class="spk gapd gap">${lab}<br>【数据缺口】(字段全空)</div>`;
const last=good[good.length-1],trend=last-good[0],col=trend>=0?'up':'down';
const miss=vals.length-good.length;
return `<div class="spk"><div class="l"><span>${lab}${miss?` <span class="gap" style="font-size:10px">缺${miss}</span>`:''}</span><span class="v ${col}">${fmt(last)}</span></div>
<canvas class="spcv" height="42" data-v='${JSON.stringify(vals)}' data-up="${trend>=0?1:0}"></canvas></div>`;}).join('')+'</div>';
requestAnimationFrame(()=>mnt.querySelectorAll('.spcv').forEach(drawSpark));
}
function drawSpark(cv){const raw=JSON.parse(cv.dataset.v),col=cv.dataset.up==='1'?CUP:CDOWN;
const dpr=devicePixelRatio||1,W=cv.clientWidth,H=42;cv.width=W*dpr;cv.height=H*dpr;
const g=cv.getContext('2d');g.setTransform(dpr,0,0,dpr,0,0);
const good=raw.filter(v=>v!=null);const mn=Math.min(...good),mx=Math.max(...good),rg=(mx-mn)||1;
const x=i=>i/(raw.length-1)*(W-4)+2,y=v=>H-4-((v-mn)/rg)*(H-9);
// null 断线(不插值、不补 0)
g.strokeStyle=col;g.lineWidth=1.4;g.beginPath();let pen=false;
raw.forEach((v,i)=>{if(v==null){pen=false;return;}if(!pen){g.moveTo(x(i),y(v));pen=true;}else g.lineTo(x(i),y(v));});
g.stroke();
// 仅在无缺口时铺渐变面积(有缺口不误导为连续)
if(good.length===raw.length){g.beginPath();raw.forEach((v,i)=>i?g.lineTo(x(i),y(v)):g.moveTo(x(i),y(v)));
g.lineTo(x(raw.length-1),H);g.lineTo(x(0),H);g.closePath();g.fillStyle=col+'22';g.fill();}}

