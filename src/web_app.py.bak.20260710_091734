h1{font-size:20px;font-weight:800;margin-bottom:4px}
.sub{color:var(--dim);font-size:12px;font-family:var(--mono);margin-bottom:18px}
.quota{display:inline-flex;gap:8px;align-items:center;background:var(--card);border:1px solid var(--border);
border-radius:8px;padding:6px 12px;font-size:12px;margin-left:12px}
.quota b{font-family:var(--mono)}
.quota.full{border-color:var(--up);color:var(--up)}
.cols{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:16px}
.col{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px}
.col h2{font-size:13px;font-weight:800;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.col h2 .n{font-family:var(--mono);color:var(--dim);font-weight:400;font-size:11px;margin-left:auto}
.dot{width:8px;height:8px;border-radius:50%}
.cell{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 10px;margin-bottom:7px;
cursor:pointer;position:relative;transition:border-color .12s}
.cell:hover{border-color:var(--accent)}
.cell.sel-exit{border-color:var(--up);box-shadow:0 0 0 1px var(--up) inset}
.cell.sel-enter{border-color:var(--down);box-shadow:0 0 0 1px var(--down) inset}
.cell .r1{display:flex;align-items:baseline;gap:8px}
.cell .nm{font-weight:700;font-size:13px}
.cell .tk{font-family:var(--mono);font-size:10px;color:var(--dim)}
.cell .sid{font-family:var(--mono);font-size:10px;color:var(--dim);margin-left:auto}
.cell .r2{display:flex;gap:10px;margin-top:5px;font-family:var(--mono);font-size:11px}
.cell .r2 span{color:var(--dim)}
.cell .r2 b{font-weight:700}
.cell .why{font-size:11px;color:var(--dim);margin-top:4px;line-height:1.4;
display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.lamp{position:absolute;top:8px;right:8px;width:7px;height:7px;border-radius:50%}
.lamp.red{background:var(--up)}.lamp.yellow{background:var(--warn)}
.badge-sel{position:absolute;top:-7px;left:8px;font-size:9px;font-weight:800;padding:1px 6px;border-radius:4px}
.badge-sel.exit{background:var(--up);color:#fff}.badge-sel.enter{background:var(--down);color:#fff}
.sec{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 18px;margin-bottom:14px}
.sec h3{font-size:13px;font-weight:800;margin-bottom:10px}
.hint{color:var(--dim);font-size:11.5px;line-height:1.7}
.legs{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:10px 0}
.leg{background:var(--bg);border:1px dashed var(--border);border-radius:8px;padding:10px 12px;min-height:62px}
.leg.on{border-style:solid}
.leg.exit.on{border-color:var(--up)}.leg.enter.on{border-color:var(--down)}
.leg .lab{font-size:11px;color:var(--dim);margin-bottom:4px}
.leg .who{font-weight:700;font-size:13px}
.leg .path{font-family:var(--mono);font-size:11px;color:var(--dim);margin-top:2px}
.leg .ph{color:var(--dim);font-size:12px}
select,textarea,input{background:var(--bg);color:var(--text);border:1px solid var(--border);
border-radius:6px;padding:6px 9px;font:inherit;font-size:12.5px;width:100%}
textarea{min-height:70px;resize:vertical;line-height:1.6}
label.f{display:block;font-size:11px;color:var(--dim);margin:10px 0 4px}
.tmpl{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
.tmpl button{background:var(--bg);border:1px solid var(--border);color:var(--dim);border-radius:5px;
padding:3px 8px;font-size:11px;cursor:pointer}
.tmpl button:hover{border-color:var(--accent);color:var(--text)}
.act{display:flex;gap:10px;align-items:center;margin-top:12px}
button.primary{background:var(--accent);color:#fff;border:none;border-radius:7px;padding:8px 18px;
font:inherit;font-weight:700;cursor:pointer}
button.primary:disabled{background:#2a3040;color:#555c6e;cursor:not-allowed}
button.ghost{background:transparent;color:var(--dim);border:1px solid var(--border);border-radius:7px;
padding:8px 14px;font:inherit;cursor:pointer}
.why-block{color:var(--warn);font-size:11.5px}
.msg{margin-top:10px;padding:10px 12px;border-radius:8px;font-size:12.5px;line-height:1.6}
.msg.err{background:rgba(226,69,62,.08);border:1px solid var(--up);color:#ffb3af}
.msg.ok{background:rgba(27,167,132,.08);border:1px solid var(--down);color:#8fe6c8}
.single{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.watch{display:flex;gap:7px;flex-wrap:wrap}
.watch .w{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:5px 9px;font-size:11.5px}
.gap{color:var(--warn);font-size:11.5px}
.perf-na{color:var(--dim)}
.foot{color:var(--dim);font-size:11px;margin-top:18px;line-height:1.8;font-family:var(--mono)}
@media(max-width:860px){.cols{grid-template-columns:1fr}.legs,.single{grid-template-columns:1fr}}
</style></head><body><div class="wrap" id="root"><div class="hint" style="padding:40px;text-align:center">加载池状态…</div></div>
<script>
const CAT={V:{c:'var(--v)',t:'V 类 · 估值'},T:{c:'var(--t)',t:'T 类 · 趋势'},N:{c:'var(--n)',t:'N 类 · 叙事'}};
const EVID_TMPL={
V:['估值分位处于历史低位','ROE / 现金流稳定,质量可验证','安全边际充足,机构目标价隐含空间','分红 / 回购持续'],
T:['5日或20日动量确认,量价配合','所属板块轮动在位','资金面净流入(北向 / 主力)','突破关键均线,趋势结构完好'],
N:['政策 / 产业主题驱动,催化明确','业绩未兑现但预期强','舆情热度显著','叙事龙头地位'],
RISK:['叙事已兑现为业绩,应迁出 N','趋势走弱,动量不再','估值已透支,安全边际消失','基本面恶化']};
let POOL=null,PERF={},SEL={exit:null,enter:null},SIGNALS={};
const esc=s=>String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const cls=v=>v==null?'':(v>0?'up':(v<0?'down':''));
const pct=v=>v==null?'<span class="perf-na">—</span>':`<b class="${cls(v)}" style="color:${v>0?'var(--up)':v<0?'var(--down)':'var(--dim)'}">${(v>0?'+':'')+v.toFixed(1)}%</b>`;

async function boot(){
try{
const r=await fetch('/api/pool');POOL=await r.json();
render();
// 涨跌异步补(带 TTL 缓存,失败不阻塞热力图)
fetch('/api/pool/perf').then(x=>x.json()).then(p=>{PERF=p.perf||{};if(p.signals)SIGNALS=p.signals;render();})
 .catch(()=>{});
}catch(e){document.getElementById('root').innerHTML=`<div class="msg err">加载池失败:${esc(e.message)}</div>`;}
}
function cellHTML(e){
const p=PERF[e.ticker]||{};const sg=SIGNALS[e.ticker];
const sel=SEL.exit&&SEL.exit.ticker===e.ticker?'sel-exit':(SEL.enter&&SEL.enter.ticker===e.ticker?'sel-enter':'');
const badge=sel==='sel-exit'?'<span class="badge-sel exit">出腿</span>':(sel==='sel-enter'?'<span class="badge-sel enter">入腿</span>':'');
const lamp=sg?`<span class="lamp ${sg.strength}" title="${esc(sg.from_cat)}→${esc(sg.to_cat)}:${esc(sg.note||'')}"></span>`:'';
return `<div class="cell ${sel}" data-tk="${esc(e.ticker)}" data-cat="${esc(e.category)}" data-nm="${esc(e.name)}">
${badge}${lamp}
<div class="r1"><span class="nm">${esc(e.name)}</span><span class="tk">${esc(e.ticker)}</span><span class="sid">${esc(e.sub_id)}</span></div>
<div class="r2"><span>5日 ${pct(p.ret_5d)}</span><span>20日 ${pct(p.ret_20d)}</span></div>
<div class="why">${esc(e.rationale||'')}</div></div>`;
