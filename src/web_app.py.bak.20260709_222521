const $ = id => document.getElementById(id);
const AGENT_ZH = __AGENT_ZH__;

function fmt(text){
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/\\*\\*([^*]+)\\*\\*/g,'<b>$1</b>');
}
function azh(agent){
  const k = (agent||'').replace(/_agent$/,'');
  return AGENT_ZH[k] || k.replace(/_/g,' ');
