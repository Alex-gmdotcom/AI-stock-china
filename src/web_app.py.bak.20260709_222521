const mn=Math.min(...vals),mx=Math.max(...vals),rg=(mx-mn)||1,x=i=>i/(vals.length-1)*(W-4)+2,y=v=>H-4-((v-mn)/rg)*(H-9);
g.beginPath();vals.forEach((v,i)=>i?g.lineTo(x(i),y(v)):g.moveTo(x(i),y(v)));g.lineTo(x(vals.length-1),H);g.lineTo(x(0),H);g.closePath();g.fillStyle=col+'22';g.fill();
g.beginPath();vals.forEach((v,i)=>i?g.lineTo(x(i),y(v)):g.moveTo(x(i),y(v)));g.strokeStyle=col;g.lineWidth=1.4;g.stroke();}

